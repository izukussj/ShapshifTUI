{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://moltui.dev/schemas/layout-definition.json",
  "title": "LayoutDefinition",
  "description": "Complete description of a MoltUI interface",
  "type": "object",
  "required": ["version", "id", "type", "root"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version - must match exactly"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this layout instance"
    },
    "type": {
      "type": "string",
      "enum": ["single", "split", "tabs", "stack"],
      "description": "Layout type determining root behavior"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "timestamp": { "type": "number" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "root": {
      "$ref": "#/definitions/Widget"
    },
    "keybindings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/KeyBinding"
      }
    },
    "theme": {
      "$ref": "#/definitions/Theme"
    }
  },
  "definitions": {
    "Widget": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique identifier within the layout"
        },
        "type": {
          "type": "string",
          "enum": [
            "container",
            "table",
            "list",
            "tree",
            "form",
            "input",
            "button",
            "text",
            "chart",
            "panel",
            "tabs",
            "modal",
            "scrollable",
            "progressbar",
            "statusbar",
            "menu",
            "notification"
          ],
          "description": "Widget type determining render behavior"
        },
        "layout": {
          "$ref": "#/definitions/LayoutProps"
        },
        "style": {
          "$ref": "#/definitions/StyleProps"
        },
        "props": {
          "type": "object",
          "description": "Type-specific configuration"
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/Widget" },
          "description": "Child widgets (for containers)"
        },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/EventHandler" }
        }
      }
    },
    "LayoutProps": {
      "type": "object",
      "properties": {
        "position": {
          "type": "string",
          "enum": ["relative", "absolute"]
        },
        "top": { "$ref": "#/definitions/SizeValue" },
        "left": { "$ref": "#/definitions/SizeValue" },
        "right": { "$ref": "#/definitions/SizeValue" },
        "bottom": { "$ref": "#/definitions/SizeValue" },
        "width": { "$ref": "#/definitions/SizeValue" },
        "height": { "$ref": "#/definitions/SizeValue" },
        "minWidth": { "type": "number" },
        "minHeight": { "type": "number" },
        "maxWidth": { "type": "number" },
        "maxHeight": { "type": "number" },
        "padding": { "$ref": "#/definitions/SpacingValue" },
        "margin": { "$ref": "#/definitions/SpacingValue" },
        "flexDirection": {
          "type": "string",
          "enum": ["row", "column"]
        },
        "justifyContent": {
          "type": "string",
          "enum": ["start", "end", "center", "space-between", "space-around"]
        },
        "alignItems": {
          "type": "string",
          "enum": ["start", "end", "center", "stretch"]
        },
        "gap": { "type": "number" },
        "flexGrow": { "type": "number" },
        "flexShrink": { "type": "number" },
        "flexBasis": { "$ref": "#/definitions/SizeValue" }
      }
    },
    "StyleProps": {
      "type": "object",
      "properties": {
        "fg": { "type": "string" },
        "bg": { "type": "string" },
        "bold": { "type": "boolean" },
        "underline": { "type": "boolean" },
        "italic": { "type": "boolean" },
        "inverse": { "type": "boolean" },
        "blink": { "type": "boolean" },
        "border": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["line", "bg", "none"]
            },
            "fg": { "type": "string" },
            "bg": { "type": "string" },
            "ch": { "type": "string" }
          }
        },
        "scrollbar": {
          "type": "object",
          "properties": {
            "track": { "type": "string" },
            "thumb": { "type": "string" }
          }
        },
        "focus": { "$ref": "#/definitions/StyleProps" },
        "hover": { "$ref": "#/definitions/StyleProps" },
        "selected": { "$ref": "#/definitions/StyleProps" }
      }
    },
    "EventHandler": {
      "type": "object",
      "required": ["on", "action"],
      "properties": {
        "on": {
          "type": "string",
          "enum": [
            "click", "dblclick", "mouseover", "mouseout", "mousewheel",
            "keypress", "focus", "blur", "select", "change", "submit", "cancel"
          ]
        },
        "action": {
          "$ref": "#/definitions/Action"
        },
        "debounce": { "type": "number" },
        "throttle": { "type": "number" }
      }
    },
    "Action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["emit", "navigate", "update", "execute"]
        },
        "target": { "type": "string" },
        "data": { "type": "object" },
        "condition": { "type": "string" }
      }
    },
    "KeyBinding": {
      "type": "object",
      "required": ["key", "action"],
      "properties": {
        "key": {
          "type": "string",
          "description": "Key combination, e.g., 'ctrl+s', 'escape', 'f1'"
        },
        "action": {
          "$ref": "#/definitions/Action"
        },
        "description": {
          "type": "string"
        },
        "when": {
          "type": "string",
          "description": "Condition when binding is active"
        }
      }
    },
    "Theme": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "background": { "type": "string" },
            "foreground": { "type": "string" },
            "error": { "type": "string" },
            "warning": { "type": "string" },
            "success": { "type": "string" },
            "info": { "type": "string" }
          }
        },
        "borders": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["line", "bg", "none"]
            },
            "fg": { "type": "string" },
            "bg": { "type": "string" }
          }
        }
      }
    },
    "SizeValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" }
      ]
    },
    "SpacingValue": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 4
        }
      ]
    }
  }
}
