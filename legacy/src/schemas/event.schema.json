{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://moltui.dev/schemas/event.json",
  "title": "Event",
  "description": "A serialized user interaction sent from MoltUI to AI backend",
  "type": "object",
  "required": ["jsonrpc", "method", "params"],
  "properties": {
    "jsonrpc": {
      "type": "string",
      "const": "2.0"
    },
    "method": {
      "type": "string",
      "const": "event"
    },
    "id": {
      "type": "string",
      "description": "Request ID for events expecting response"
    },
    "params": {
      "type": "object",
      "required": ["sessionId", "layoutId", "widgetId", "eventType", "data", "timestamp"],
      "properties": {
        "sessionId": {
          "type": "string",
          "description": "Current session identifier"
        },
        "layoutId": {
          "type": "string",
          "description": "Current layout identifier"
        },
        "widgetId": {
          "type": "string",
          "description": "Widget that triggered the event"
        },
        "eventType": {
          "type": "string",
          "enum": [
            "click",
            "dblclick",
            "mouseover",
            "mouseout",
            "mousewheel",
            "keypress",
            "focus",
            "blur",
            "select",
            "change",
            "submit",
            "cancel",
            "resize",
            "scroll"
          ]
        },
        "data": {
          "type": "object",
          "description": "Event-specific data"
        },
        "timestamp": {
          "type": "number",
          "description": "Unix timestamp in milliseconds"
        }
      }
    }
  }
}
