{
  "name": "moltui",
  "version": "1.0.0",
  "description": "A chat-integrated TUI framework for AI assistants to present dynamic, interactive interfaces",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "moltui": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "mock-server": "node mock-server/server.js",
    "llm-backend": "node mock-server/llm-backend.js",
    "manual": "node mock-server/manual-backend.js",
    "demo": "node dist/cli.js ws://localhost:8080",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tui",
    "terminal",
    "ui",
    "ai",
    "chat",
    "blessed",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@babel/parser": "^7.29.0",
    "@google/generative-ai": "^0.24.1",
    "ajv": "^8.12.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chatgpt-websocket": "^1.0.1",
    "fast-json-patch": "^3.1.1",
    "isolated-vm": "^6.0.2",
    "openai": "^6.17.0",
    "uuid": "^13.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
