{
  "name": "shapeshiftui",
  "version": "2.0.0",
  "description": "Chat-driven TUI where the AI ships React/Ink components that run in a sandbox",
  "type": "module",
  "bin": {
    "shapeshiftui": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "mock": "node mock-server/server.js",
    "bridge": "node server/bridge.js",
    "demo": "node dist/cli.js ws://localhost:8080",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "esbuild": "^0.24.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "openai": "^6.34.0",
    "react": "^18.3.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.12",
    "@types/ws": "^8.5.10",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
