{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://moltui.dev/schemas/layout-definition.json",
  "title": "LayoutDefinition",
  "description": "Complete description of a MoltUI interface",
  "type": "object",
  "required": ["version", "id", "type", "root"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version - must match exactly"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this layout instance"
    },
    "type": {
      "type": "string",
      "enum": ["single", "split", "tabs", "stack"],
      "description": "Layout type determining root behavior"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "timestamp": { "type": "number" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "root": {
      "$ref": "widget.schema.json"
    },
    "keybindings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/KeyBinding"
      }
    },
    "theme": {
      "$ref": "#/definitions/Theme"
    }
  },
  "definitions": {
    "KeyBinding": {
      "type": "object",
      "required": ["key", "action"],
      "properties": {
        "key": {
          "type": "string",
          "description": "Key combination, e.g., 'ctrl+s', 'escape', 'f1'"
        },
        "action": {
          "$ref": "#/definitions/Action"
        },
        "description": {
          "type": "string"
        },
        "when": {
          "type": "string",
          "description": "Condition when binding is active"
        }
      }
    },
    "Action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["emit", "navigate", "update", "execute"]
        },
        "target": {
          "type": "string"
        },
        "data": {
          "type": "object"
        },
        "condition": {
          "type": "string"
        }
      }
    },
    "Theme": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "background": { "type": "string" },
            "foreground": { "type": "string" },
            "error": { "type": "string" },
            "warning": { "type": "string" },
            "success": { "type": "string" },
            "info": { "type": "string" }
          }
        },
        "borders": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["line", "bg", "none"]
            },
            "fg": { "type": "string" },
            "bg": { "type": "string" }
          }
        }
      }
    }
  }
}
